# CarerPoint shared design system is published to GitHub Packages.
# The @lana-care scope must resolve from GitHub Packages (org-scoped registry).
@lana-care:registry=https://npm.pkg.github.com

# CI must provide a read:packages token so `bun install` can fetch @lana-care/*:
#   //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
# (set NODE_AUTH_TOKEN / GITHUB_TOKEN with read:packages in the workflow env).
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
